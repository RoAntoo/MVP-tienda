generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Producto {
  id       String  @id @default(uuid()) @db.Uuid
  titulo   String
  precio   Decimal
  driveUrl String  @map("drive_url")
  ordenes  Orden[] @relation("OrdenProductos")

  @@map("productos")
}

model Orden {
  id           String     @id @default(uuid()) @db.Uuid
  emailCliente String     @map("customer_email")
  total        Decimal
  estado       String // Valores: PENDIENTE o APROBADO
  productos    Producto[] @relation("OrdenProductos")

  @@map("ordenes")
}
