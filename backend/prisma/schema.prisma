generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Producto {
  id        String   @id @default(uuid()) @db.Uuid
  titulo    String
  precio    Decimal  @db.Decimal(10, 2)
  driveUrl  String   @map("drive_url")
  ordenes   Orden[]  @relation("OrdenProductos")

  @@map("productos")
}

model Orden {
  id            String       @id @default(uuid()) @db.Uuid
  emailCliente  String       @map("customer_email")
  total         Decimal      @db.Decimal(10, 2)
  estado        EstadoOrden
  productos     Producto[]   @relation("OrdenProductos")

  @@map("ordenes")
}

enum EstadoOrden {
  PENDIENTE
  APROBADO
  DESPACHADO
}
