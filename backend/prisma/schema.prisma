generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Producto {
  id          String   @id @default(uuid())
  titulo      String
  precio      Decimal
  descripcion String
  categoria   String   @default("General")
  imagenUrl   String   @map("imagen_url")
  driveUrl    String   @map("drive_url")
  createdAt   DateTime @default(now())
  ordenes     Orden[]  @relation("OrdenProductos")

  @@map("productos")
}

model Orden {
  id            String       @id @default(uuid())
  emailCliente  String       @map("customer_email")
  total         Decimal
  estado        String       @default("PENDIENTE") // SQLite no admite enums en el schema de Prisma
  productos     Producto[]   @relation("OrdenProductos")

  @@map("ordenes")
}


